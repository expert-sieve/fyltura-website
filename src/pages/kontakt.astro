---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
---

<Layout
  title="Kontakt - FYLTURA | Demo buchen & Beratung"
  description="Kontaktieren Sie FYLTURA für eine kostenlose Demo oder Beratung zu Coding Tests und Persönlichkeitstests. Tel: +49 341-39 29 48 04"
  canonical="/kontakt/"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary to-primary/90 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Kontaktieren Sie uns
      </h1>
      <p class="text-xl text-gray-200">
        Gern sind wir für Sie da
      </p>
    </div>
  </section>

  <Section>
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Sprechen Sie mit uns</h2>
        <p class="text-gray-600 mb-8">
          Vereinbaren Sie eine kostenlose 30-minütige Demo oder stellen Sie uns Ihre Fragen.
          Wir freuen uns auf den Austausch mit Ihnen.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">Telefon</h3>
              <a href="tel:+4934139294804" class="text-accent hover:underline">+49 341-39 29 48 04</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">E-Mail</h3>
              <a href="mailto:kontakt@fyltura.de" class="text-accent hover:underline">kontakt@fyltura.de</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">Adresse</h3>
              <p class="text-gray-600">
                Expert Sieve UG (haftungsbeschränkt)<br />
                Wilhelm-Raabe-Str. 6<br />
                04416 Markkleeberg
              </p>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div class="mt-8 pt-8 border-t border-gray-200">
          <h3 class="font-semibold mb-4">Folgen Sie uns</h3>
          <div class="flex gap-4">
            <a
              href="https://www.linkedin.com/company/fyltura/"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 bg-primary text-white rounded-lg flex items-center justify-center hover:bg-primary/90 transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
            <a
              href="https://twitter.com/FYLTURA"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 bg-primary text-white rounded-lg flex items-center justify-center hover:bg-primary/90 transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-xl p-8 shadow-lg border border-gray-100">
        <h2 class="text-2xl font-bold mb-6">Kontaktformular</h2>
        <p class="text-gray-600 mb-6">
          Füllen Sie das Formular aus und wir melden uns zeitnah bei Ihnen.
        </p>

        <!-- Google Form -->
        <div class="flex justify-center">
          <a
            href="https://forms.gle/8XMVrcQEu934cUUB9"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-accent text-white font-semibold py-3 px-8 rounded-lg hover:bg-accent/90 transition-colors text-lg"
          >
            Zum Kontaktformular
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </Section>
</Layout>
