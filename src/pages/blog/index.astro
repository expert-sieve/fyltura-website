---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get unique categories with counts
const categories = ['Alle', ...new Set(posts.map(p => p.data.category))];
const categoryCounts = posts.reduce((acc, post) => {
  acc[post.data.category] = (acc[post.data.category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categoryIcons: Record<string, string> = {
  'Persönlichkeit': '🧠',
  'Experteninterviews': '🎤',
  'Eignungsdiagnostik': '📊',
  'HR Praxis': '👥',
  'Unternehmen': '🏢',
  'default': '📝'
};

const categoryColors: Record<string, string> = {
  'Persönlichkeit': 'from-purple-500 to-indigo-600',
  'Experteninterviews': 'from-accent to-orange-600',
  'Eignungsdiagnostik': 'from-emerald-500 to-teal-600',
  'HR Praxis': 'from-primary to-blue-700',
  'Unternehmen': 'from-gray-500 to-gray-700',
  'default': 'from-primary to-primary/80'
};
---

<Layout
  title="Blog - FYLTURA | HR Insights & Recruiting-Tipps"
  description="Neues aus dem HR Lab: Artikel zu Coding Tests, Persönlichkeitstests, Eignungsdiagnostik und modernem Recruiting."
  canonical="/blog/"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary to-primary/90 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block bg-white/10 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
        HR Insights & Best Practices
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        Neues aus dem HR Lab
      </h1>
      <p class="text-xl text-gray-200 max-w-2xl mx-auto leading-relaxed">
        Insights zu Eignungsdiagnostik, Persönlichkeitstests und modernem IT-Recruiting
      </p>
    </div>
  </section>

  <Section>
    <!-- Category Filter Tabs -->
    <div class="mb-10">
      <div class="flex flex-wrap gap-2 justify-center" id="category-filters">
        {categories.map((category) => (
          <button
            data-category={category}
            class={`category-btn px-4 py-2 rounded-full text-sm font-medium transition-all ${
              category === 'Alle'
                ? 'bg-primary text-white'
                : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
            }`}
          >
            {category}
            {category !== 'Alle' && (
              <span class="ml-1.5 text-xs opacity-70">({categoryCounts[category]})</span>
            )}
          </button>
        ))}
      </div>
    </div>

    {posts.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-gray-500">Noch keine Blogbeiträge verfügbar.</p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
        {posts.map((post, index) => {
          const gradient = categoryColors[post.data.category] || categoryColors['default'];
          const icon = categoryIcons[post.data.category] || categoryIcons['default'];
          const isFirst = index === 0;

          return (
            <article
              data-category={post.data.category}
              class={`post-card group bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg hover:border-gray-200 transition-all duration-300 ${isFirst ? 'md:col-span-2 lg:col-span-2' : ''}`}
            >
              <a href={`/blog/${post.id}/`} class="block">
                {post.data.image ? (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class={`w-full object-cover ${isFirst ? 'h-48 md:h-64' : 'h-40'}`}
                  />
                ) : (
                  <div class={`w-full ${isFirst ? 'h-48 md:h-64' : 'h-40'} bg-gradient-to-br ${gradient} flex items-center justify-center relative overflow-hidden`}>
                    <div class="absolute inset-0 opacity-10">
                      <div class="absolute top-4 left-4 w-24 h-24 border-2 border-white rounded-full"></div>
                      <div class="absolute bottom-6 right-6 w-32 h-32 border-2 border-white rounded-full"></div>
                    </div>
                    <span class={`${isFirst ? 'text-6xl' : 'text-4xl'} relative z-10`}>{icon}</span>
                  </div>
                )}
              </a>
              <div class="p-5">
                <div class="flex flex-wrap items-center gap-2 text-sm text-gray-500 mb-3">
                  <span class="bg-accent/10 text-accent px-2.5 py-0.5 rounded-full text-xs font-semibold">
                    {post.data.category}
                  </span>
                  {post.data.series && (
                    <span class="bg-primary/10 text-primary px-2.5 py-0.5 rounded-full text-xs font-medium">
                      {post.data.series}
                    </span>
                  )}
                </div>
                <h2 class={`font-bold mb-2 group-hover:text-accent transition-colors leading-tight ${isFirst ? 'text-xl md:text-2xl' : 'text-lg'}`}>
                  <a href={`/blog/${post.id}/`} class="text-primary group-hover:text-accent transition-colors">
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between">
                  <time datetime={post.data.pubDate.toISOString()} class="text-xs text-gray-400">
                    {post.data.pubDate.toLocaleDateString('de-DE', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                  <a
                    href={`/blog/${post.id}/`}
                    class="inline-flex items-center gap-1 text-accent font-semibold text-sm group-hover:gap-2 transition-all"
                  >
                    Lesen
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}

    <!-- Post count -->
    <div class="mt-8 text-center">
      <p class="text-gray-500 text-sm">
        <span id="visible-count">{posts.length}</span> von {posts.length} Artikeln
      </p>
    </div>
  </Section>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-card.hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.category-btn');
    const postCards = document.querySelectorAll('.post-card');
    const visibleCount = document.getElementById('visible-count');
    const totalCount = postCards.length;

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const category = button.getAttribute('data-category');

        // Update active button styling
        filterButtons.forEach(btn => {
          btn.classList.remove('bg-primary', 'text-white');
          btn.classList.add('bg-gray-100', 'text-gray-600');
        });
        button.classList.remove('bg-gray-100', 'text-gray-600');
        button.classList.add('bg-primary', 'text-white');

        // Filter posts
        let visible = 0;
        postCards.forEach(card => {
          const cardCategory = card.getAttribute('data-category');
          if (category === 'Alle' || cardCategory === category) {
            card.classList.remove('hidden');
            visible++;
          } else {
            card.classList.add('hidden');
          }
        });

        // Update count
        if (visibleCount) {
          visibleCount.textContent = visible.toString();
        }
      });
    });
  });
</script>
