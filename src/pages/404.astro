---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
---

<Layout title="Seite nicht gefunden - FYLTURA">
  <section class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center">
      <h1 class="text-6xl md:text-8xl font-bold text-primary mb-4">404</h1>
      <p class="text-2xl text-gray-600 mb-8">Seite nicht gefunden</p>
      <p class="text-gray-500 mb-8 max-w-md mx-auto">
        Die angeforderte Seite existiert nicht oder wurde verschoben.
      </p>
      <Button href="/" variant="primary">
        Zur Startseite
      </Button>
    </div>
  </section>
</Layout>
