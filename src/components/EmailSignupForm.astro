---
interface Props {
  variant?: 'inline' | 'sidebar';
  formId?: string;
}
const { variant = 'inline', formId = `signup-${Math.random().toString(36).slice(2, 8)}` } = Astro.props;
---

<div
  id={formId}
  class:list={[
    'fyltura-signup',
    variant === 'inline'
      ? 'bg-gradient-to-br from-primary/5 to-primary/10 rounded-2xl p-6 md:p-8 border border-primary/10'
      : 'bg-white rounded-xl p-5 shadow-sm border border-gray-100',
  ]}
>
  <!-- Header -->
  <div class="flex items-start gap-3 mb-4">
    <span class="text-2xl leading-none mt-0.5">📥</span>
    <div>
      <h3 class:list={['font-bold text-primary', variant === 'inline' ? 'text-xl' : 'text-base']}>
        SMB HR-Toolkit kostenlos sichern
      </h3>
      <p class:list={['text-gray-600 mt-1 leading-snug', variant === 'sidebar' ? 'text-sm' : 'text-sm md:text-base']}>
        Holen Sie sich das SMB HR-Toolkit – 10 Fragen vor jedem Coding Test. 1-Seiten-PDF, kein Spam.
      </p>
    </div>
  </div>

  <!-- Form -->
  <form class="signup-form" novalidate>
    <input type="hidden" name="utm_source" />
    <input type="hidden" name="utm_medium" />
    <input type="hidden" name="utm_campaign" />

    <div class:list={['flex flex-col gap-2', variant === 'inline' && 'sm:flex-row sm:items-end']}>
      <div class:list={['flex flex-col gap-2', variant === 'inline' ? 'flex-1' : 'w-full']}>
        {variant === 'inline' && (
          <input
            type="text"
            name="firstName"
            placeholder="Vorname (optional)"
            autocomplete="given-name"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary bg-white"
          />
        )}
        <input
          type="email"
          name="email"
          required
          placeholder="Ihre E-Mail-Adresse *"
          autocomplete="email"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary bg-white"
        />
      </div>
      <button
        type="submit"
        class:list={[
          'bg-accent hover:bg-accent/90 active:bg-accent/80 text-white font-semibold rounded-lg transition-colors text-sm whitespace-nowrap cursor-pointer',
          variant === 'sidebar' ? 'w-full py-2.5 px-4' : 'px-6 py-2.5',
        ]}
      >
        Gratis PDF sichern
      </button>
    </div>

    <!-- DSGVO consent -->
    <label class="flex items-start gap-2 mt-3 cursor-pointer group">
      <input
        type="checkbox"
        name="consent"
        required
        class="mt-0.5 w-4 h-4 rounded border-gray-300 accent-primary cursor-pointer flex-shrink-0"
      />
      <span class="text-xs text-gray-500 group-hover:text-gray-700 transition-colors leading-relaxed">
        Ich stimme zu, dass FYLTURA mich per E-Mail kontaktiert. Abmeldung jederzeit möglich. Mehr in der
        <a href="/datenschutz/" class="underline hover:text-primary" target="_blank" rel="noopener">Datenschutzerklärung</a>.
      </span>
    </label>

    <p class="signup-error hidden text-xs text-red-600 mt-2"></p>
  </form>

  <!-- Success state (hidden until submission) -->
  <div class="signup-success hidden text-center py-4">
    <span class="text-3xl block mb-2">✅</span>
    <p class="font-semibold text-primary">Vielen Dank!</p>
    <p class="text-sm text-gray-600 mt-1">Bitte bestätigen Sie Ihre Anmeldung per E-Mail.</p>
  </div>
</div>

<script>
  function initForm(root: HTMLElement) {
    const form = root.querySelector<HTMLFormElement>('.signup-form');
    const success = root.querySelector<HTMLElement>('.signup-success');
    const errorEl = root.querySelector<HTMLElement>('.signup-error');
    if (!form) return;

    // Populate UTM hidden fields from current URL
    const params = new URLSearchParams(window.location.search);
    for (const key of ['utm_source', 'utm_medium', 'utm_campaign'] as const) {
      const input = form.querySelector<HTMLInputElement>(`[name="${key}"]`);
      const val = params.get(key);
      if (input && val) input.value = val;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const email = form.querySelector<HTMLInputElement>('[name="email"]')?.value.trim();
      const consent = form.querySelector<HTMLInputElement>('[name="consent"]')?.checked;

      if (!email || !consent) {
        if (errorEl) {
          errorEl.textContent = !email
            ? 'Bitte geben Sie Ihre E-Mail-Adresse ein.'
            : 'Bitte stimmen Sie der Datenschutzerklärung zu.';
          errorEl.classList.remove('hidden');
        }
        return;
      }

      if (errorEl) errorEl.classList.add('hidden');
      if (btn) { btn.disabled = true; btn.textContent = 'Wird gesendet…'; }

      const fd = new FormData(form);
      fd.set('consent', '1');

      try {
        const res = await fetch('/api/subscribe', { method: 'POST', body: fd });
        const json = await res.json() as { success?: boolean; error?: string };
        if (json.success) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
        } else {
          if (errorEl) { errorEl.textContent = json.error ?? 'Ein Fehler ist aufgetreten.'; errorEl.classList.remove('hidden'); }
          if (btn) { btn.disabled = false; btn.textContent = 'Gratis PDF sichern'; }
        }
      } catch {
        if (errorEl) { errorEl.textContent = 'Netzwerkfehler. Bitte versuchen Sie es erneut.'; errorEl.classList.remove('hidden'); }
        if (btn) { btn.disabled = false; btn.textContent = 'Gratis PDF sichern'; }
      }
    });
  }

  document.querySelectorAll<HTMLElement>('.fyltura-signup').forEach(initForm);
</script>
