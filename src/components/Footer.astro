---
const footerLinks = {
  produkte: [
    { name: 'Coding Tests', href: '/coding-tests/' },
    { name: 'Persönlichkeitstest', href: '/persoenlichkeitstest/' },
  ],
  unternehmen: [
    { name: 'Lösungen', href: '/loesungen/' },
    { name: 'Preise', href: '/preise/' },
    { name: 'Blog', href: '/blog/' },
    { name: 'Kontakt', href: '/kontakt/' },
  ],
  rechtliches: [
    { name: 'Impressum', href: '/impressum/' },
    { name: 'Datenschutz', href: '/datenschutz/' },
    { name: 'AGB', href: '/agb/' },
  ],
};

const socialLinks = [
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/company/fyltura/',
    icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z'
  },
  {
    name: 'Twitter',
    href: 'https://twitter.com/FYLTURA',
    icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z'
  },
];
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-1">
        <img src="/images/fyltura_logo.svg" alt="FYLTURA" class="h-8 w-auto brightness-0 invert" />
        <p class="mt-4 text-gray-300 text-sm">
          Coding Tests und Persönlichkeitstests für die objektive Personalauswahl.
          100% DSGVO-konform. Made in Germany.
        </p>
        <div class="mt-4 flex space-x-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-300 hover:text-white transition-colors"
              aria-label={social.name}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Produkte -->
      <div>
        <h3 class="font-semibold mb-4">Produkte</h3>
        <ul class="space-y-2">
          {footerLinks.produkte.map((link) => (
            <li>
              <a href={link.href} class="text-gray-300 hover:text-white transition-colors text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div>
        <h3 class="font-semibold mb-4">Unternehmen</h3>
        <ul class="space-y-2">
          {footerLinks.unternehmen.map((link) => (
            <li>
              <a href={link.href} class="text-gray-300 hover:text-white transition-colors text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Rechtliches -->
      <div>
        <h3 class="font-semibold mb-4">Rechtliches</h3>
        <ul class="space-y-2">
          {footerLinks.rechtliches.map((link) => (
            <li>
              <a href={link.href} class="text-gray-300 hover:text-white transition-colors text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-6 text-sm text-gray-300">
          <p>+49 341-39 29 48 04</p>
          <p>kontakt@fyltura.de</p>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-600 text-center text-sm text-gray-400">
      <p>&copy; {new Date().getFullYear()} Expert Sieve UG (haftungsbeschränkt). Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>
