---
interface Props {
  quote: string;
  author: string;
  role: string;
  company: string;
}

const { quote, author, role, company } = Astro.props;
---

<div class="bg-white rounded-lg p-8 shadow-sm border border-gray-100">
  <svg class="w-8 h-8 text-accent/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
  </svg>
  <blockquote class="text-gray-700 text-lg mb-4">{quote}</blockquote>
  <div>
    <p class="font-semibold text-primary">{author}</p>
    <p class="text-gray-500 text-sm">{role}, {company}</p>
  </div>
</div>
